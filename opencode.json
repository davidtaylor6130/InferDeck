{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "inferdeck": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "InferDeck",
      "options": {
        "baseURL": "http://192.168.0.168:11434/v1"
      },
      "models": {
        "qwen3.6-35b-a3b:latest": {
          "name": "qwen3.6-35b-a3b",
          "limit": { "context": 262144, "output": 16384 },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "qwen3-coder-30b-a3b:latest": {
          "name": "qwen3-coder-30b-a3b",
          "limit": { "context": 262144, "output": 16384 },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "gemma-4-26b-a4b:latest": {
          "name": "gemma-4-26b-a4b",
          "limit": { "context": 262144, "output": 16384 },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gpt-oss-20b:latest": {
          "name": "gpt-oss-20b",
          "limit": { "context": 131072, "output": 16384 },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "qwen2.5-coder-3b:latest": {
          "name": "qwen2.5-coder-3b",
          "limit": { "context": 32768, "output": 16384 },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "qwen3.6-27b:latest": {
          "name": "qwen3.6-27b",
          "limit": { "context": 65536, "output": 16384 },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "inferdeck/qwen3.6-35b-a3b:latest",
  "small_model": "inferdeck/qwen2.5-coder-3b:latest",
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@mohak34/opencode-notifier@latest",
    "@mbanucu/opencode-background",
    "opencode-ignore",
    "superbased-opencode-plugin"
  ],
  "mcp": {
    "puppeteer-screenshot-mcp": {
      "type": "local",
      "command": ["npx", "-y", "puppeteer-screenshot-mcp"],
      "enabled": true
    }
  }
}