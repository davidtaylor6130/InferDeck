{
  "name": "gateway-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-bundle/main.js",
  "bin": "dist-bundle/main.js",
  "scripts": {
    "dev": "node --import tsx src/main.ts",
    "build": "tsc",
    "bundle": "node build-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "prestart": "pnpm build",
    "start": "node dist/main.js",
    "test": "cd ../.. && node_modules/.pnpm/node_modules/.bin/vitest run",
    "dist": "pnpm build && pnpm bundle && npx @yao-pkg/pkg . --targets node22-win-x64,node22-linux-x64 --public --output release/inferdeck-gateway"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/static": "^7.0.0",
    "@r9700/backend-llama": "workspace:*",
    "@r9700/gateway-core": "workspace:*",
    "@r9700/shared": "workspace:*",
    "sql.js": "^1.11.0",
    "fastify": "^4.28.0",
    "fp-ts": "^2.16.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "tslib": "^2.8.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "pkg": {
    "outputPath": "release",
    "scripts": [
      "dist-bundle/main.js"
    ],
    "assets": [
      "dist-bundle/sql-wasm.wasm",
      "dist-bundle/db/migrations/**/*",
      "dist-bundle/public/**/*",
      "dist-bundle/config/**/*"
    ]
  }
}
